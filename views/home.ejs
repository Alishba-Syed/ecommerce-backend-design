<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ShopEase – Home</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

  <!-- NAV -->
<nav>
  <div class="nav-inner">
    <a href="/" class="logo">Shop<span>Ease</span></a>
    
    <ul class="nav-links">
      <li><a href="/" class="active">Home</a></li>
      <li><a href="/products">Products</a></li>
      <li><a href="/#categories">Categories</a></li>
      <li><a href="/#features">About</a></li>
    </ul>
    
    <div class="nav-actions">
      <a href="/products" class="btn-cart">&#128722; Cart (0)</a>
      <button class="hamburger" id="hamburger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
  
  <div class="mobile-menu" id="mobileMenu">
    <a href="/">Home</a>
    <a href="/products">Products</a>
    <a href="/#categories">Categories</a>
    <a href="/#features">About</a>
  </div>
</nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-badge">New Arrivals 2026</div>
      <h1>Discover Amazing <span>Products</span> You'll Love</h1>
      <p>Shop thousands of curated items across every category — all at competitive prices with fast, free shipping.</p>
      <div class="hero-cta">
       <a href="/products" class="btn-primary">Shop Now</a>
      <a href="/#featured" class="btn-outline">View Featured</a>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <div class="stats-bar">
    <div class="stats-inner">
      <div class="stat-item"><h3>10K+</h3><p>Products Available</p></div>
      <div class="stat-item"><h3>50K+</h3><p>Happy Customers</p></div>
      <div class="stat-item"><h3>99%</h3><p>Satisfaction Rate</p></div>
      <div class="stat-item"><h3>24/7</h3><p>Customer Support</p></div>
    </div>
  </div>

  <!-- CATEGORIES -->
  <section class="categories" id="categories">
    <div class="section-inner">
      <div class="section-header">
        <h2>Shop by Category</h2>
        <p>Find exactly what you're looking for</p>
      </div>
      <div class="categories-grid">

        <a href="/products" class="category-card">
          <img src="/images/cat-electronics.jpg" alt="Electronics" />
          <div class="category-info">
            <h3>Electronics</h3>
            <span>320 products</span>
          </div>
        </a>

        <a href="/products" class="category-card">
          <img src="/images/cat-fashion.jpg" alt="Fashion" />
          <div class="category-info">
            <h3>Fashion</h3>
            <span>480 products</span>
          </div>
        </a>

        <a href="/products" class="category-card">
          <img src="/images/cat-home.jpg" alt="Home and Living" />
          <div class="category-info">
            <h3>Home &amp; Living</h3>
            <span>260 products</span>
          </div>
        </a>

        <a href="/products" class="category-card">
          <img src="/images/cat-books.jpg" alt="Books" />
          <div class="category-info">
            <h3>Books</h3>
            <span>150 products</span>
          </div>
        </a>

      </div>
    </div>
  </section>

 <section class="featured" id="featured">
  <div class="section-inner">
    <div class="section-header">
      <h2>Featured Products</h2>
      <p>Handpicked just for you — our bestsellers this week</p>
    </div>
    <div class="products-grid">

      <!-- Database se aane wale products par loop shuru -->
      <% productsArr.forEach(product => { %>
        <div class="product-card">
          <div class="product-img">
            <!-- Agar database mein badge hai to dikhaye, nahi to 'New' default -->
            <span class="product-badge"><%= product.badge || 'New' %></span>
            <!-- Database ki real image -->
            <img src="<%= product.image %>" alt="<%= product.name %>" />
          </div>
          <div class="product-info">
            <!-- Database ka real name -->
            <div class="product-name"><%= product.name %></div>
            <div class="product-rating">&#9733;&#9733;&#9733;&#9733;&#9733; <span>(128)</span></div>
            <div class="product-footer">
              <div class="product-price">
                <!-- Database ki real price -->
                $<%= product.price %>
              </div>
              <!-- Product ki specific ID par bhejne ke liye link -->
              <a href="/products/<%= product._id %>" class="btn-add">View</a>
            </div>
          </div>
        </div>
      <% }) %>

    </div>
  </div>
</section>

  <!-- PROMO BANNER -->
  <div class="promo-banner">
    <h2>Summer Sale — Up to 50% Off!</h2>
    <p>Limited time offer. Don't miss out on our biggest sale of the year.</p>
    <a href="/products" class="btn-outline" style="border-color:rgba(255,255,255,0.6); font-size:0.95rem;">Browse All Deals</a>
  </div>

  <!-- FEATURES / WHY US -->
  <section class="features" id="features">
    <div class="section-inner">
      <div class="section-header">
        <h2>Why Choose ShopEase?</h2>
        <p>We make online shopping simple, safe, and satisfying</p>
      </div>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">&#128666;</div>
          <h4>Free Shipping</h4>
          <p>Free delivery on orders over $30 — no hidden fees, ever.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">&#128274;</div>
          <h4>Secure Payments</h4>
          <p>Your data is protected with bank-level SSL encryption.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">&#128260;</div>
          <h4>Easy Returns</h4>
          <p>30-day hassle-free returns — no questions asked.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">&#128222;</div>
          <h4>24/7 Support</h4>
          <p>Our team is always here to help you, any time of day.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="footer-inner">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="logo">Shop<span>Ease</span></a>
          <p>Your one-stop destination for quality products at unbeatable prices. Shop smarter, live better.</p>
        </div>
        <div class="footer-col">
          <h5>Shop</h5>
          <ul>
            <li><a href="/products">All Products</a></li>
            <li><a href="#">New Arrivals</a></li>
            <li><a href="#">Best Sellers</a></li>
            <li><a href="#">Deals &amp; Offers</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h5>Support</h5>
          <ul>
            <li><a href="#">Help Center</a></li>
            <li><a href="#">Track Order</a></li>
            <li><a href="#">Returns</a></li>
            <li><a href="#">Contact Us</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h5>Company</h5>
          <ul>
            <li><a href="#">About Us</a></li>
            <li><a href="#">Careers</a></li>
            <li><a href="#">Privacy Policy</a></li>
            <li><a href="#">Terms of Use</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <span>&copy; 2026 ShopEase. All rights reserved.</span>
        <span>Made with &#10084;&#65039; for great shopping</span>
      </div>
    </div>
  </footer>

  <script>
    document.getElementById('hamburger').addEventListener('click', () => {
      document.getElementById('mobileMenu').classList.toggle('open');
    });
  </script>
</body>
</html>
