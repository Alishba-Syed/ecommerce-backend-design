<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ShopEase – Products</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>

  <!-- NAV -->
  <nav>
  <div class="nav-inner">
    <a href="/" class="logo">Shop<span>Ease</span></a>
    
    <ul class="nav-links">
      <li><a href="/">Home</a></li>
      <li><a href="/products" class="active">Products</a></li>
      <li><a href="/#categories">Categories</a></li>
      <li><a href="/#features">About</a></li>
    </ul>
    
    <div class="nav-actions">
      <a href="#" class="btn-cart">&#128722; Cart (0)</a>
      <button class="hamburger" id="hamburger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
  
  <div class="mobile-menu" id="mobileMenu">
    <a href="/">Home</a>
    <a href="/products">Products</a>
    <a href="/#categories">Categories</a>
    <a href="/#features">About</a>
  </div>
</nav>

  <!-- PAGE HEADER -->
  <div class="page-header">
    <div class="page-header-inner">
      <div class="breadcrumb">
        <a href="/">Home</a> &rsaquo; Products
      </div>
      <h1>All Products</h1>
      <p>Showing 120 results across all categories</p>
    </div>
  </div>

 <!-- SEARCH + SORT BAR -->
<div class="search-bar-section">
  <div class="search-bar-inner">
    
    <!-- Humne input ko form ke andar wrap kiya hai taake GET request chal sakay -->
    <form action="/products" method="GET" class="search-input-wrap" style="display: flex; flex: 1; align-items: center;">
      <span class="search-icon">&#128269;</span>
      <!-- name="search" dalna sab se zaroori tha -->
      <input 
        type="text" 
        name="search" 
        placeholder="Search products..." 
        id="searchInput" 
      />
      <!-- Chaho to enter maro, ya chota sa submit button laga lo (optional) -->
      <button type="submit" style="padding: 5px 10px; margin-left: 5px;">Search</button>
    </form>

    <select class="sort-select" id="sortSelect">
      <option>Sort: Featured</option>
      <option>Price: Low to High</option>
      <option>Price: High to Low</option>
      <option>Newest First</option>
      <option>Best Rating</option>
    </select>
  </div>
</div>

  <!-- MAIN LAYOUT -->
  <div class="shop-layout">

    <!-- SIDEBAR FILTERS -->
    <aside class="sidebar" id="sidebar">

      <div class="filter-card">
        <h4>Categories</h4>
        <ul class="filter-list">
          <li><label><input type="checkbox" checked /> All Products</label><span class="filter-count">120</span></li>
          <li><label><input type="checkbox" /> Electronics</label><span class="filter-count">32</span></li>
          <li><label><input type="checkbox" /> Fashion</label><span class="filter-count">48</span></li>
          <li><label><input type="checkbox" /> Home &amp; Living</label><span class="filter-count">26</span></li>
          <li><label><input type="checkbox" /> Books</label><span class="filter-count">14</span></li>
        </ul>
      </div>

      <div class="filter-card">
        <h4>Price Range</h4>
        <div class="price-range">
          <input type="range" min="0" max="500" value="250" id="priceRange" />
          <div class="price-labels">
            <span>$0</span>
            <span id="priceLabel">$250</span>
          </div>
        </div>
      </div>

      <div class="filter-card">
        <h4>Rating</h4>
        <ul class="filter-list rating-filter">
          <li><label><input type="checkbox" /> &#9733;&#9733;&#9733;&#9733;&#9733; <span>&amp; up</span></label></li>
          <li><label><input type="checkbox" /> &#9733;&#9733;&#9733;&#9733;&#9734; <span>&amp; up</span></label></li>
          <li><label><input type="checkbox" /> &#9733;&#9733;&#9733;&#9734;&#9734; <span>&amp; up</span></label></li>
          <li><label><input type="checkbox" /> &#9733;&#9733;&#9734;&#9734;&#9734; <span>&amp; up</span></label></li>
        </ul>
      </div>

      <div class="filter-card">
        <h4>Availability</h4>
        <ul class="filter-list">
          <li><label><input type="checkbox" checked /> In Stock</label></li>
          <li><label><input type="checkbox" /> On Sale</label></li>
          <li><label><input type="checkbox" /> New Arrivals</label></li>
        </ul>
      </div>

      <button class="btn-clear-filter">Clear All Filters</button>

    </aside>

    <!-- PRODUCT AREA -->
    <main class="product-area">

      <button class="filter-toggle-btn" id="filterToggle">&#9776; Filters</button>

      <div class="product-area-header">
        <p class="result-count">Showing <strong><%= productsArr.length %></strong> products</p>
        <div class="view-toggle">
          <button class="view-btn active" id="gridViewBtn" title="Grid view">&#9783;</button>
          <button class="view-btn" id="listViewBtn" title="List view">&#9776;</button>
        </div>
      </div>

 <div class="products-grid" id="productsGrid">

        <% productsArr.forEach(product => { %>
          
          <div class="product-card">
            <div class="product-img">
              <span class="product-badge">New</span>
              <button class="wishlist-btn" aria-label="Wishlist">&#9825;</button>
              <img src="<%= product.image %>" alt="<%= product.name %>" />
            </div>
            <div class="product-info">
              <div class="product-category"><%= product.category %></div>
              <div class="product-name"><%= product.name %></div>
              <div class="product-rating">&#9733;&#9733;&#9733;&#9733;&#9733; <span>(128)</span></div>
              <div class="product-footer">
                <div class="product-price">Rs. <%= product.price %></div>
                <a href="/products/<%= product._id %>" class="btn-add">View Details</a>
              </div>
            </div>
          </div>

        <% }); %>
        </div>

     <!-- DYNAMIC PAGINATION CODE  -->
<div class="pagination">
  
  <!-- Previous Button -->
  <% if (currentPage > 1) { %>
    <a href="/products?page=<%= currentPage - 1 %>&search=<%= searchQuery %>" class="page-btn" style="text-decoration: none;">&#8249;</a>
  <% } else { %>
    <button class="page-btn" disabled>&#8249;</button>
  <% } %>

  <!-- Current Page Info Display -->
  <span style="padding: 0 10px; align-self: center; font-weight: bold; font-family: sans-serif;">
    <%= currentPage %> / <%= totalPages %>
  </span>

  <!-- Next Button -->
  <% if (currentPage < totalPages) { %>
    <a href="/products?page=<%= currentPage + 1 %>&search=<%= searchQuery %>" class="page-btn" style="text-decoration: none;">&#8250;</a>
  <% } else { %>
    <button class="page-btn" disabled>&#8250;</button>
  <% } %>

</div>

  <!-- FOOTER -->
  <footer>
    <div class="footer-inner">
      <div class="footer-bottom">
        <span>&copy; 2026 ShopEase. All rights reserved.</span>
        <span><a href="/" style="color:#aab4c8;text-decoration:none;">&#8592; Back to Home</a></span>
      </div>
    </div>
  </footer>

  <script>
    document.getElementById('hamburger').addEventListener('click', () => {
      document.getElementById('mobileMenu').classList.toggle('open');
    });

    document.getElementById('filterToggle').addEventListener('click', () => {
      document.getElementById('sidebar').classList.toggle('open');
    });

    const priceRange = document.getElementById('priceRange');
    priceRange.addEventListener('input', () => {
      document.getElementById('priceLabel').textContent = '$' + priceRange.value;
    });

    const gridViewBtn = document.getElementById('gridViewBtn');
    const listViewBtn = document.getElementById('listViewBtn');
    const grid = document.getElementById('productsGrid');

    gridViewBtn.addEventListener('click', () => {
      grid.classList.remove('list-view');
      gridViewBtn.classList.add('active');
      listViewBtn.classList.remove('active');
    });

    listViewBtn.addEventListener('click', () => {
      grid.classList.add('list-view');
      listViewBtn.classList.add('active');
      gridViewBtn.classList.remove('active');
    });

    document.querySelectorAll('.page-btn:not([disabled])').forEach(btn => {
      btn.addEventListener('click', function () {
        document.querySelectorAll('.page-btn').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
      });
    });
  </script>
</body>
</html>
